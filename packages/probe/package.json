{
  "name": "@stentorosaur/probe",
  "version": "0.2.0",
  "description": "Monitoring engine and I/O for Stentorosaur (ADR-005 §1). All fetching (HTTP checks, GitHub API, git writes) lives here; transforms live in @stentorosaur/core.",
  "license": "MIT",
  "author": "Amiable Development <dev@amiable.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amiable-dev/docusaurus-plugin-stentorosaur.git",
    "directory": "packages/probe"
  },
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    },
    "./worker": {
      "types": "./lib/worker.d.ts",
      "default": "./lib/worker.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "worker": [
        "lib/worker.d.ts"
      ]
    }
  },
  "files": [
    "lib",
    "bin"
  ],
  "scripts": {
    "build": "tsc --build",
    "prepare": "npm run build",
    "test": "jest"
  },
  "dependencies": {
    "@stentorosaur/core": "^0.2.0",
    "jiti": "^2.4.0",
    "aws4fetch": "^1.0.20",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.5",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.19"
  },
  "bin": {
    "stentorosaur": "bin/stentorosaur.cjs"
  },
  "publishConfig": {
    "access": "public"
  }
}
